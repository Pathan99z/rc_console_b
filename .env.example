APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Primary storage disk: local (dev) | s3 (staging/production)
FILESYSTEM_DISK=local
# Optional global override (defaults to FILESYSTEM_DISK when unset)
# APP_STORAGE_DISK=
# Optional per-module overrides (unset = use APP_STORAGE_DISK / FILESYSTEM_DISK)
# QUOTE_STORAGE_DISK=
# COLLATERAL_STORAGE_DISK=
# IMPORT_STORAGE_DISK=
# Presigned URL lifetime (minutes)
# STORAGE_SIGNED_URL_MINUTES=10
# COLLATERAL_SIGNED_URL_MINUTES=10
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=
# CACHE_PREFIX=rc-console-cache-

# Enterprise cache (mail queued when QUEUE_CONNECTION is not sync)
ENTERPRISE_CACHE_MAIL_QUEUE=true

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
# Public/CDN base URL for object URLs (optional; recommended for production)
AWS_URL=
# Custom S3-compatible endpoint (MinIO, etc.)
# AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PayFast (optional tenant-level settings override these in /api/settings/payment)
PAYFAST_SANDBOX_URL=https://sandbox.payfast.co.za/eng/process
PAYFAST_LIVE_URL=https://www.payfast.co.za/eng/process
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_MODE=sandbox
PAYFAST_DEFAULT_RETURN_PATH=/billing/payfast/return
PAYFAST_DEFAULT_CANCEL_PATH=/billing/payfast/cancel
PAYFAST_NOTIFY_URL=
FRONTEND_URL=http://localhost:5173
PAYFAST_SUCCESS_REDIRECT_URL=http://localhost:5173/login
PAYFAST_CANCEL_REDIRECT_URL=http://localhost:5173/login
PRM_INVITE_EXPIRY_DAYS=7
PRM_INVITE_ACCEPT_URL=http://localhost:5173/partner/accept
PRM_AUTO_VERIFY_INVITED_USERS=false
